{$DOMAIN:example.com} {
  encode gzip zstd

  handle_path /_/backend/* {
    reverse_proxy 127.0.0.1:4000
  }

  handle /assets/* {
    header Cache-Control "public, max-age=31536000, immutable"
    reverse_proxy 127.0.0.1:5173
  }

  handle {
    reverse_proxy 127.0.0.1:5173
  }
}
